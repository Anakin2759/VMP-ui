If:
  PathExclude: [third_party/.*]

CompileFlags:
  CompilationDatabase: build
  Compiler: clang-cl
  Add:
    - "--std=c++23"
    - "-Wno-unused-parameter"
    - "-Wno-missing-field-initializers"

Diagnostics:
  Suppress:
    - "unused-parameter"
    - "c++98-compat"
    - "c++98-compat-pedantic"

Index:
  Background: Build

---
# 公共聚合头（include/ui.hpp）没有自己的 TU，clangd 无法从 compile_commands 推断。
# 在此显式补全所需 include 路径与宏，确保独立打开时也能解析所有传递依赖。
If:
  PathMatch: [include/.*\.hpp]

CompileFlags:
  Add:
    - "-I."
    - "-Isrc"
    - "-Iinclude"
    - "-Ithird_party/entt/src"
    - "-Ithird_party/asio/include"
    - "-Ithird_party/eigen-5.0.0"
    - "-Ithird_party/spdlog/include"
    - "-DASIO_STANDALONE"
    - "-DASIO_DISABLE_STD_EXECUTION"
    - "-DNOMINMAX"
    - "-DWIN32_LEAN_AND_MEAN"

